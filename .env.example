# Copy this file to .env and fill in real values. Do NOT commit .env (it is gitignored).

# --- LLM provider (required, fail-fast in src/model_factory.py) ---
LLM_PROVIDER=                 # bedrock | openai | anthropic
LLM_PROVIDER_MODEL=           # model id for the chosen provider

# --- Provider credentials / service keys ---
# Get an Anthropic key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=            # required if LLM_PROVIDER=anthropic
# Get an OpenAI key: https://platform.openai.com/api-keys
OPENAI_API_KEY=               # required if LLM_PROVIDER=openai
# Bedrock uses your AWS credentials (env/profile/role) instead of a key here.
# Enable model access: https://console.aws.amazon.com/bedrock/home#/modelaccess

# Get a Tavily key (free tier): https://app.tavily.com/home
TAVILY_API_KEY=               # web recipe search
# Get a Hugging Face token: https://huggingface.co/settings/tokens
HF_TOKEN=                     # Hugging Face token for embeddings
USER_AGENT=                   # User-Agent string for outbound web requests

# --- LangSmith tracing (optional) ---
# Get a LangSmith key: https://smith.langchain.com/settings
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=
LANGSMITH_PROJECT=

# --- Vector store (PostgreSQL + pgvector) ---
# Required. psycopg3 driver. Stand up the database with deploy/ (see deploy/README.md).
DATABASE_URL=                 # e.g. postgresql+psycopg://dev:devpass@localhost:5433/appdb
